# =========================================================================
# TikTube Tools - PRODUCTION CORE ENVIRONMENT VARIABLES (.env.example)
# Production Ready Domain: https://TikTubeTools.com
# =========================================================================

# 1. CORE WEB OPERATIONS
DOMAIN_URL="https://TikTubeTools.com"
SITE_NAME="TikTube Tools"
ADMIN_EMAIL="aerogaming.2023@gmail.com"

# APP_URL: Injected automatically by hosting or cloud container instances
APP_URL="https://TikTubeTools.com"

# 2. WORDPRESS INTEGRATION STUDIO SETTINGS
WORDPRESS_URL="https://TikTubeTools.com/blog"
WORDPRESS_API_URL="https://TikTubeTools.com/blog/wp-json/wp/v2"

# 3. DIRECT COGNITIVE LLM KEYS (SECURE CLOUD STORAGE ONLY)
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# 4. DATABASE PERISTANT CONFIGURATIONS
# Supported providers: filesystem (for zero-config docker/JSON storage) or database (relational Postgres)
DB_PROVIDER="filesystem" 
DB_HOST="localhost"
DB_PORT=5432
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_SSL=false

# 5. AUDIO TRANSCRIPTION SYSTEM ENGINE CONTROLS
WHISPER_MODEL="large-v3"
STT_PROVIDER="gemini"

# 6. STANDALONE SECURE ADMIN DASHBOARD
JWT_SECRET="xyz-tiktube-jwt-super-secret-key-2026"
ADMIN_DASHBOARD_EMAIL="aerorca.21@gmail.com"
# Bcrypt hash of "@@admin-/147147@@"
ADMIN_DASHBOARD_PASSWORD_HASH="$2a$10$tZ2pE3R5rA2/G78kKk9N8.WvA7I6Mvq0mU3CgV3T2R8S3sI9X7Z5q"
# Backup Bcrypt hash for alternative secure access (e.g., "@@admindegogh-/147147@@")
BACKUP_ADMIN_PASSWORD_HASH="$2a$10$3XzIDv8pYg5JlypGj6VwS.AEvHptpE2w6U6N60Mqy0U8VvO2y9z1q"

# 7. PRODUCTION NETLIFY & CLOUD RUN DECOUPLING SETTINGS
# FRONTEND_URL: Used by the Cloud Run backend to securely configure production CORS policies
FRONTEND_URL="https://your-netlify-app.netlify.app"
# VITE_API_URL: Used by the Netlify frontend to proxy relative fetch calls to Cloud Run
VITE_API_URL="https://your-cloud-run-backend-url.run.app"

